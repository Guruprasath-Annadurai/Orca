# ── Orca Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Data directory ────────────────────────────────────────────────────────────
ORCA_HOME=~/.orca

# ── License key signing secret ────────────────────────────────────────────────
# REQUIRED before generating or verifying license keys at scale.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ORCA_LICENSE_SECRET=change-me-before-distributing

# ── Stripe integration ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY powers POST /api/billing/checkout (creates the Checkout
# Session a logged-in web user is redirected to). Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET verifies webhook signatures. Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PRO_YEAR=price_...
STRIPE_PRICE_ENT=price_...
STRIPE_PRICE_ENT_YEAR=price_...
# Base URL used for Stripe Checkout success/cancel redirects — set to your
# real domain in production (e.g. https://app.yourdomain.com).
ORCA_PUBLIC_URL=http://localhost:7337

# ── Email delivery ────────────────────────────────────────────────────────────
# Used to email license keys to customers immediately after payment.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password
SMTP_FROM=Orca <no-reply@yourdomain.com>

# ── Ollama (optional overrides) ───────────────────────────────────────────────
# ORCA_OLLAMA_HOST=http://localhost:11434
# ORCA_CORE_MODEL=orca
# ORCA_NANO_MODEL=orca-nano
# ORCA_ULTRA_MODEL=orca

# ── Nvidia Nemotron (optional distillation teacher only, not live chat) ───────
# Only needed if using orca/train/distill.py with a "nvidia/*" teacher model
# (e.g. nvidia/nemotron-3-ultra-550b-a55b). Get a key at build.nvidia.com.
# NVIDIA_API_KEY=nvapi-...
